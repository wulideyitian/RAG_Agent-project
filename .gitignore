# ========== 数据文件（不提交知识库文档）==========
# 知识库文档（PDF、Word 等二进制文件）
data/*.pdf
data/*.docx
data/*.doc

# 知识库文本文件（避免知识库文档过大）
data/*.txt
data/*.csv
data/*.md

# 外部数据文件
data/external/*.csv

# 上传的文件目录
data/uploads/

# ========== PyCharm 缓存 ==========
.idea/
*.iml

# Python 虚拟环境
venv/
env/
.venv/
ENV/

# Python 依赖包（可选，如果不想提交依赖）
# requirements.txt

# 编译文件
__pycache__/
*.py[cod]
*.so
*.pyd
*.class

# ========== 日志与缓存 ==========
# 日志文件
logs/
*.log

# 临时文件和缓存
*.tmp
.cache/
models/
*.bin
*.pth

# 系统文件
.DS_Store
Thumbs.db

# 配置文件（敏感信息）
*.env
.env.local
.env.*.local

# 数据库文件（向量库数据）
chroma_db/*
*.sqlite3

# MD5 记录文件
md5.text

# 临时文件
*.swp
*.swo
*~

# IDE 配置（可选）
.vscode/
.settings/
.project
.pydevproject

# Jupyter Notebook 检查点
.ipynb_checkpoints/

# pytest 缓存
.pytest_cache/

# coverage 报告
htmlcov/
.coverage
.coverage.*

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Node.js (前端)
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/.env.*.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/.DS_Store